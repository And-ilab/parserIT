# Опционально: пока можно не задавать — в it_parser.py остаются прежние значения по умолчанию.
# Когда будете готовы вынести секреты с диска, скопируйте в .env (файл .env не коммитьте).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Необязательно: число попыток sendMessage при сетевых сбоях (по умолчанию 6).
# TELEGRAM_SEND_RETRIES=6

# Необязательно: JSON с полями отраслей icetrade (см. icetrade_industry_params.example.json и docstring в it_parser.py).
# ICETRADE_PARAMS_JSON=C:\tender_it\icetrade_industry_params.json
# Необязательно: одна строка — значение скрытого поля industries после выбора отраслей на сайте (перекрывает JSON).
# ICETRADE_INDUSTRIES=
# Отключить встроенный фильтр по отраслям (ИТ+компьютеры):
# ICETRADE_DISABLE_DEFAULT_INDUSTRY=1

# ---------- Парсер ангаров (angar_parser.py при использовании общего ядра icetrade_parser_core.py)
# По умолчанию без рубрикатора icetrade — только ключевые слова и чёрный список ангаров.
# Включить отрасли позже: скопировать параметр industries из URL поиска или скрытого поля формы.
# ANGAR_ICETRADE_INDUSTRIES=
# Альтернатива: отдельный JSON рядом с ангарным парсером:
# ANGAR_ICETRADE_PARAMS_JSON=C:\tender_it\icetrade_industry_params_angar.json
# Или полностью убрать industries из запроса, если задали в JSON и нужно сбросить:
# ANGAR_ICETRADE_INDUSTRIES=off
# Опционально: свои токен/чат/mention (иначе как у ИТ):
# ANGAR_TELEGRAM_BOT_TOKEN=
# ANGAR_TELEGRAM_CHAT_ID=
# ANGAR_TELEGRAM_MENTION=@YesisGennady
